#!csharp

#r "nuget: Azure.AI.OpenAI, 2.1.0"

#!csharp

using Azure;
using Azure.AI.OpenAI;
using OpenAI.Chat;
using System.ClientModel;
using static System.Environment;

string endpoint = "<replace with endpoint>";
string key = "<replace with API key>";

// Enter the deployment name you chose when you deployed the model (for example: gpt-4o-mini).
string deployment = "<replace with deployment>";

AzureOpenAIClient azureClient = new(new Uri(endpoint), new ApiKeyCredential(key));
ChatClient chatClient = azureClient.GetChatClient(deployment);

string prompt = "Complete the following: Once upon a time there was a";
Console.Write($"Input: {prompt}\n");

ChatCompletion completion = chatClient.CompleteChat(new UserChatMessage(prompt));
Console.WriteLine($"Chatbot: {completion.Content[0].Text}");

#!csharp

Console.Write("No of recipes (for example, 5): ");
string no_recipes = "2";

Console.Write("List of ingredients (for example, chicken, potatoes, and carrots): ");
string ingredients = "chocolate";

Console.Write("Filter (for example, vegetarian, vegan, or gluten-free): ");
string filter = "peanuts";

// interpolate the number of recipes into the prompt an ingredients
string prompt = $"Show me {no_recipes} recipes for a dish with the following ingredients: {ingredients}. Per recipe, list all the ingredients used, no {filter}: ";

#!csharp

// deployment, prompt, max output tokens, temperature
ChatCompletionOptions options = new()
{
    MaxOutputTokenCount = 150,
    Temperature = 0.1f,
};

ChatCompletion completion = chatClient.CompleteChat(
    new[] { new UserChatMessage(prompt) },
    options);
Console.WriteLine("==== Recipes ====");
Console.WriteLine($"Chatbot: {completion.Content[0].Text}");
