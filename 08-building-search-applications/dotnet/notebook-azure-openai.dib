#!meta

{"kernelInfo":{"defaultKernelName":"csharp","items":[{"aliases":[],"name":"csharp"}]}}

#!csharp

#r "nuget: Azure.AI.OpenAI, 2.1.0"

#!csharp

using Azure.AI.OpenAI;
using OpenAI.Embeddings;
using System.ClientModel;

#!csharp

#r "nuget:Microsoft.DotNet.Interactive.AIUtilities, 1.0.0-beta.23557.4"

using Microsoft.DotNet.Interactive;
using Microsoft.DotNet.Interactive.AIUtilities;

#!csharp

var azureOpenAIKey = "<replace with API key>";
var azureOpenAIEndpoint = "<replace with endpoint>";
var deployment = "<replace with deployment name, e.g. a text-embedding-3-small deployment>";

#!csharp

AzureOpenAIClient azureClient = new(new Uri(azureOpenAIEndpoint), new ApiKeyCredential(azureOpenAIKey));
EmbeddingClient client = azureClient.GetEmbeddingClient(deployment);

#!csharp

var source = "Car";
var compareTo = "Vehicle";
var parrot = "A bird";

OpenAIEmbedding parrotEmbeddings = await client.GenerateEmbeddingAsync(parrot);

// vector version
OpenAIEmbedding embeddings = await client.GenerateEmbeddingAsync(source);

// vector version
OpenAIEmbedding embeddingsCompareTo = await client.GenerateEmbeddingAsync(compareTo);

Console.WriteLine($"Generated an embedding for: {source}");
Console.WriteLine($"Generated an embedding for: {compareTo}");

#!csharp

var comparer = new CosineSimilarityComparer<float[]>(f => f);
var carArray = embeddings.ToFloats().ToArray(); // float []
var vehicleArray = embeddingsCompareTo.ToFloats().ToArray(); // float []
var parrotArray = parrotEmbeddings.ToFloats().ToArray(); // float []

var score = comparer.Score(carArray, vehicleArray);
Console.WriteLine(score);

score = comparer.Score(carArray, parrotArray);
Console.WriteLine(score);
